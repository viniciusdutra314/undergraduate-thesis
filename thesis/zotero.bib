@article{dearrudaMinimalPathsCommunities2016,
	title = {Minimal paths between communities induced by geographical networks},
	volume = {2016},
	issn = {1742-5468},
	url = {https://iopscience.iop.org/article/10.1088/1742-5468/2016/02/023403},
	doi = {10.1088/1742-5468/2016/02/023403},
	abstract = {In this work we investigate the betweenness centrality in geographical networks and its relationship with network communities. We show that vertices with large betweenness deﬁne what we call characteristic betweenness paths in both modeled and real-world geographical networks. We deﬁne a geographical network model that possesses a simple topology while still being able to present such betweenness paths. Using this model, we show that such paths represent pathways between entry and exit points of highly connected regions, or communities, of geographical networks. By deﬁning a new network, containing information about community adjacencies in the original network, we describe a means to characterize the mesoscale connectivity provided by such characteristic betweenness paths.},
	pages = {023403},
	number = {2},
	journaltitle = {Journal of Statistical Mechanics: Theory and Experiment},
	shortjournal = {J. Stat. Mech.},
	author = {De Arruda, Henrique Ferraz and Comin, César Henrique and Da Fontoura Costa, Luciano},
	urldate = {2026-05-20},
	date = {2016-02-24},
	langid = {english},
}

